            "job-profiles",
            "{{jobProfileId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('job profile deleted', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('deleted true', function () { pm.expect(body.deleted).to.eql(true); });"
            ]
