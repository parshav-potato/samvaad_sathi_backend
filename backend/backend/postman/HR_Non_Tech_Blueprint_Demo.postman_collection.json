            "exec": [
              "pm.test('v2 summary report fetched', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "14 Cleanup HR Job Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/v2/job-profiles/{{jobProfileId}}",
          "host": [
            "{{baseUrl}}{{apiPrefix}}"
          ],
          "path": [
